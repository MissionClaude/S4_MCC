# =============================================================================
# Scenario 4: Developer Productivity with Claude — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
# .env is git-ignored — never commit real credentials.

# --- Anthropic API ---
# Required. Get yours at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Model Selection ---
# Which Claude model to use for agent operations.
# Options: claude-haiku (fast/cheap), claude-sonnet (balanced), claude-opus (powerful)
# Default: claude-haiku
CLAUDE_MODEL=claude-haiku

# --- Rate Limiting ---
# Max requests per minute to the Anthropic API.
# Default: 50
ANTHROPIC_MAX_RPM=50

# --- Timeouts ---
# Max seconds to wait for a single API call.
# Default: 120
ANTHROPIC_TIMEOUT_SECONDS=120

# --- Context Management ---
# Max conversation turns before triggering /compact
# Default: 15
MAX_CONVERSATION_TURNS=15

# Scratchpad file location for preserving findings across sessions
# Default: .scratchpad.md
SCRATCHPAD_PATH=.scratchpad.md

# --- MCP Configuration ---
# Path to MCP configuration file
# Default: .mcp.json
MCP_CONFIG_PATH=.mcp.json

# GitHub token for MCP GitHub server integration (optional)
# GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Pipeline Mode ---
# When set to "true", agents run in non-interactive mode (equivalent to -p flag)
# Default: false
PIPELINE_MODE=false

# --- Logging ---
# Log level: DEBUG, INFO, WARNING, ERROR
# Default: INFO
LOG_LEVEL=INFO
